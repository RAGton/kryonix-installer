{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kryonix Backend Install Plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "hostname": { "type": "string", "minLength": 1 },
    "timezone": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "minLength": 1 },
    "keyboard": { "type": "string", "minLength": 1 },
    "disk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["dry-run", "install", "real"] },
        "target": { "type": "string", "pattern": "^/dev/(sd[a-z]|vd[a-z]|nvme[0-9]+n[0-9]+)$" },
        "layout": { "enum": ["btrfs-simple", "lvm-simple"] },
        "boot_mode": { "enum": ["uefi", "bios"] },
        "profile": { "enum": ["single", "raid", "manual"] },
        "selectedDisks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^/dev/(sd[a-z]|vd[a-z]|nvme[0-9]+n[0-9]+)$" },
          "uniqueItems": true
        },
        "raidLevel": { "enum": ["raid0", "raid1", "raid5", "raid10"] },
        "manualPartitions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["device", "fstype", "sizeBytes", "sizeInput", "usage", "format"],
            "properties": {
              "id": { "type": "string" },
              "device": { "type": "string", "pattern": "^/dev/(sd[a-z]|vd[a-z]|nvme[0-9]+n[0-9]+)$" },
              "sizeBytes": { "type": "number", "minimum": 0 },
              "sizeInput": { "type": "string" },
              "usage": { "enum": ["efi", "root", "home", "swap", "data", "custom"] },
              "fstype": { "enum": ["fat32", "btrfs", "ext4", "xfs", "swap", "vfat"] },
              "mountpoint": { "type": "string" },
              "label": { "type": "string" },
              "partLabel": { "type": "string" },
              "flags": { "type": "array", "items": { "type": "string" } },
              "size": { "type": "string" },
              "format": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["mode", "target", "layout", "boot_mode", "profile"]
    },
    "user": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "admin": { "type": "boolean" }
      },
      "required": ["name", "admin"]
    },
    "features": { "type": "object" }
  },
  "required": ["version", "hostname", "timezone", "locale", "keyboard", "disk", "user", "features"]
}
